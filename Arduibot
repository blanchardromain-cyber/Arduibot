<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ArduinoBot — Assistant pédagogique</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f1117;
    --surface: #1a1d27;
    --surface2: #22263a;
    --border: #2e3350;
    --accent: #00d4aa;
    --accent2: #4f8fff;
    --accent3: #ff6b6b;
    --amber: #ffb347;
    --text: #e8ecf4;
    --muted: #8b92a8;
    --radius: 14px;
    --font-main: 'Nunito', sans-serif;
    --font-mono: 'Space Mono', monospace;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--font-main);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 14px;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .logo {
    width: 44px; height: 44px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono);
    font-size: 13px; font-weight: 700; color: #0f1117;
    flex-shrink: 0;
  }

  .header-info h1 { font-size: 16px; font-weight: 800; color: var(--text); }
  .header-info p { font-size: 12px; color: var(--accent); font-weight: 600; }

  .status-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 6px var(--accent);
    margin-left: auto;
  }

  .topics-bar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 10px 16px;
    display: flex; gap: 8px; overflow-x: auto;
    scrollbar-width: none;
  }
  .topics-bar::-webkit-scrollbar { display: none; }

  .topic-btn {
    flex-shrink: 0;
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--muted);
    font-size: 12px; font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .topic-btn:hover { border-color: var(--accent); color: var(--accent); }

  #chat {
    flex: 1;
    overflow-y: auto;
    padding: 24px 16px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    max-width: 820px;
    width: 100%;
    margin: 0 auto;
  }

  .msg { display: flex; gap: 12px; animation: fadeIn 0.3s ease; }
  .msg.user { flex-direction: row-reverse; }

  .avatar {
    width: 36px; height: 36px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 15px; flex-shrink: 0; font-weight: 700;
  }
  .avatar.bot { background: linear-gradient(135deg, var(--accent), var(--accent2)); color: #0f1117; font-size: 11px; font-family: var(--font-mono); }
  .avatar.user { background: var(--surface2); border: 1px solid var(--border); color: var(--muted); }

  .bubble {
    max-width: 75%;
    padding: 12px 16px;
    border-radius: var(--radius);
    line-height: 1.65;
    font-size: 14.5px;
    word-wrap: break-word;
  }
  .msg.bot .bubble { background: var(--surface); border: 1px solid var(--border); border-top-left-radius: 4px; }
  .msg.user .bubble { background: rgba(0,212,170,0.12); border: 1px solid rgba(0,212,170,0.25); border-top-right-radius: 4px; }

  .bubble strong { color: var(--accent); }
  .bubble code { font-family: var(--font-mono); background: var(--surface2); padding: 2px 5px; color: var(--accent2); border-radius: 4px; }

  .input-area {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 14px 16px;
    max-width: 820px;
    width: 100%;
    margin: 0 auto;
  }

  .input-row { display: flex; gap: 10px; align-items: flex-end; }

  #userInput {
    flex: 1;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 11px 14px;
    color: var(--text);
    font-size: 14px;
    resize: none;
    outline: none;
    min-height: 46px;
  }

  #sendBtn {
    width: 46px; height: 46px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
  }
  #sendBtn:disabled { opacity: 0.3; }

  /* ZONE CLE API */
  #keySetup {
    background: var(--surface2);
    border: 1px solid var(--border);
    padding: 15px;
    margin: 10px auto;
    max-width: 820px;
    border-radius: 10px;
  }
  #apiKeyInput {
    background: var(--bg);
    border: 1px solid var(--border);
    color: white;
    padding: 8px;
    width: 70%;
    border-radius: 5px;
  }
  #saveKeyBtn {
    padding: 8px 15px;
    background: var(--accent);
    border: none;
    border-radius: 5px;
    cursor: pointer;
    font-weight: bold;
  }

  .typing { display: flex; gap: 5px; padding: 10px; }
  .dot { width: 6px; height: 6px; background: var(--accent); border-radius: 50%; animation: bounce 1.4s infinite; }
  @keyframes bounce { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
</style>
</head>
<body>

<header>
  <div class="logo">ARD</div>
  <div class="header-info">
    <h1>ArduinoBot</h1>
    <p>Assistant pédagogique — Collège</p>
  </div>
  <div class="status-dot"></div>
</header>

<div id="keySetup">
  <p style="font-size: 12px; margin-bottom: 8px;">🔑 Configuration : Entre ta clé API Google Gemini pour activer le bot.</p>
  <input type="password" id="apiKeyInput" placeholder="Colle ta clé AIzaSy... ici">
  <button id="saveKeyBtn" onclick="saveKey()">Activer</button>
</div>

<div class="topics-bar">
  <button class="topic-btn" onclick="quickTopic('capteurs')">🔍 Capteurs</button>
  <button class="topic-btn" onclick="quickTopic('actionneurs')">⚙️ Actionneurs</button>
  <button class="topic-btn" onclick="quickTopic('arduino')">🔌 Carte Arduino</button>
  <button class="topic-btn" onclick="quickTopic('codecraft')">🧩 Codecraft</button>
</div>

<div id="chat"></div>

<div class="input-area">
  <div class="input-row">
    <textarea id="userInput" placeholder="Pose ta question ici..." rows="1" onkeydown="handleKey(event)"></textarea>
    <button id="sendBtn" onclick="sendMessage()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
    </button>
  </div>
</div>

<script>
let apiKey = localStorage.getItem('arduino_bot_key') || '';
let conversationHistory = [];
let isWaiting = false;

// Masquer la config si la clé existe déjà
if(apiKey) document.getElementById('keySetup').style.display = 'none';

const SYSTEM_PROMPT = `Tu es ArduinoBot, un assistant pour élèves de collège (11-15 ans). 
Tu aides sur Arduino Uno et Codecraft (programmation par blocs).
Règles :
1. Langage simple, bienveillant.
2. Explique les branchements (GND, 5V, Signal).
3. Ne donne pas la solution brute, guide l'élève.
4. Utilise des emojis.
5. Réponds en Français uniquement.`;

function saveKey() {
    const val = document.getElementById('apiKeyInput').value.trim();
    if(val.startsWith('AIza')) {
        apiKey = val;
        localStorage.setItem('arduino_bot_key', val);
        document.getElementById('keySetup').style.display = 'none';
        addWelcomeMessage();
    } else {
        alert("La clé semble invalide (elle doit commencer par AIza...)");
    }
}

function addWelcomeMessage() {
    appendMessage('bot', "👋 **Bonjour !** Je suis prêt à t'aider. Pose-moi une question sur tes montages Arduino ou tes blocs Codecraft !");
}

function appendMessage(role, text) {
    const chat = document.getElementById('chat');
    const msgDiv = document.createElement('div');
    msgDiv.className = `msg ${role}`;
    
    const html = text
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/`(.*?)`/g, '<code>$1</code>')
        .replace(/\n/g, '<br>');

    msgDiv.innerHTML = `
        <div class="avatar ${role}">${role==='bot'?'ARD':'👤'}</div>
        <div class="bubble">${html}</div>
    `;
    chat.appendChild(msgDiv);
    chat.scrollTop = chat.scrollHeight;
}

async function sendMessage() {
    if (!apiKey || isWaiting) return;
    const input = document.getElementById('userInput');
    const text = input.value.trim();
    if (!text) return;

    input.value = '';
    isWaiting = true;
    appendMessage('user', text);
    
    // Format pour Gemini
    conversationHistory.push({ role: "user", parts: [{ text: text }] });
    
    // Affichage chargement
    const typing = document.createElement('div');
    typing.id = 'loader';
    typing.innerHTML = '<div class="typing"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>';
    document.getElementById('chat').appendChild(typing);

    try {
        const resp = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-lite:generateContent?key=${apiKey}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                contents: conversationHistory,
                systemInstruction: { parts: [{ text: SYSTEM_PROMPT }] }
            })
        });

        const data = await resp.json();
        document.getElementById('loader').remove();

        if (data.candidates && data.candidates[0].content) {
            const reply = data.candidates[0].content.parts[0].text;
            appendMessage('bot', reply);
            conversationHistory.push({ role: "model", parts: [{ text: reply }] });
        } else {
            throw new Error("Erreur de réponse API");
        }
    } catch (e) {
        document.getElementById('loader').remove();
        appendMessage('bot', "❌ Désolé, j'ai un problème de connexion. Vérifie ta clé API.");
        console.error(e);
    } finally {
        isWaiting = false;
    }
}

function handleKey(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } }
function quickTopic(t) { 
    const q = { capteurs: "C'est quoi un capteur ?", arduino: "Explique moi la carte Arduino Uno", codecraft: "Comment faire clignoter une LED ?", actionneurs: "C'est quoi un servomoteur ?" };
    document.getElementById('userInput').value = q[t];
    sendMessage();
}

if(apiKey) addWelcomeMessage();
</script>
</body>
</html>
